{
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchDatasources": ["golang-version"],
      "allowedVersions": "1.25"
    },
    {
      "groupName": "Darvaza Projects",
      "groupSlug": "darvaza",
      "matchPackageNames": [
        "darvaza.org/**"
      ]
    }
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ]
}
